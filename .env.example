# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_USER=devlife
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=devlife
DATABASE_URL=postgres://devlife:change_me_in_production@localhost:5432/devlife

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── API Server ────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=change_this_to_a_long_random_string_at_least_64_chars

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create at: https://github.com/settings/applications/new
# Callback URL: http://localhost:3000/auth/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:3001/auth/github/callback

# ── Frontend ──────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Home Assistant (optional) ─────────────────────────────────────────────────
# Random string used as Bearer token for /ha/* endpoints
HA_API_KEY=generate_a_random_key_here

# ── Sync ──────────────────────────────────────────────────────────────────────
# How often to run background syncs (cron expression)
SYNC_CRON=0 * * * *
# Days of history to fetch on first connect
INITIAL_SYNC_DAYS=365
